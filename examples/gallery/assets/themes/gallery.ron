(
  default_variant: "dark",
  rules: [
    (
      selector: Class("gallery.root"),
      setter: (
        layout: (
          padding: Var("space-xl"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("fill-layer-background"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
    (
      selector: Class("gallery.top_bar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-lg"),
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
          justify_content: SpaceBetween,
          align_items: Center,
        ),
        colors: (
          bg: Var("fill-layer-default"),
          border: Var("border-default"),
        ),
      ),
    ),
    (
      selector: Class("gallery.brand"),
      setter: (
        layout: (
          gap: Var("gap-sm"),
          align_items: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.title"),
      setter: (
        colors: (
          text: Var("text-heading"),
        ),
        text: (
          size: 18.0,
          weight: 600,
        ),
      ),
    ),
    (
      selector: Class("gallery.subtitle"),
      setter: (
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: Var("text-sm"),
        ),
      ),
    ),
    (
      selector: Class("gallery.search_row"),
      setter: (
        layout: (
          align_items: Center,
          gap: Var("gap-md"),
        ),
      ),
    ),
    (
      selector: Class("gallery.search"),
      setter: (
        layout: (
          padding: Var("space-md"),
        ),
        colors: (
          bg: Var("surface-subtle"),
        ),
      ),
    ),
    (
      selector: Class("gallery.tools"),
      setter: (
        layout: (
          gap: Var("gap-sm"),
          align_items: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.status"),
      setter: (
        layout: (
          padding: Var("space-md"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("fill-layer-alt"),
          border: Var("border-default"),
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.body"),
      setter: (
        layout: (
          gap: Var("gap-md"),
          align_items: Stretch,
        ),
      ),
    ),
    (
      selector: Class("gallery.content_area"),
      setter: (
        layout: (
          gap: Var("gap-md"),
          align_items: Stretch,
        ),
      ),
    ),
    (
      selector: Class("nav.sidebar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("space-xs"),
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("fill-layer-alt"),
          border: Var("border-default"),
        ),
      ),
    ),
    (
      selector: Class("gallery.sidebar_category"),
      setter: (
        layout: (
          padding: Var("space-sm"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: 11.0,
          weight: 600,
        ),
      ),
    ),
    (
      selector: Class("nav.item"),
      setter: (
        layout: (
          padding: 8.0,
          corner_radius: Var("radius-md"),
          border_width: 0.0,
          justify_content: Start,
        ),
        colors: (
          bg: Var("transparent"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
          text: Var("text-primary"),
        ),
        text: (
          size: Var("text-sm"),
        ),
      ),
    ),
    (
      selector: Class("nav.item.active"),
      setter: (
        colors: (
          bg: Var("surface-accent"),
          hover_bg: Var("surface-accent-hover"),
          pressed_bg: Var("surface-accent-pressed"),
          text: Var("text-on-accent"),
        ),
      ),
    ),
    (
      selector: Class("gallery.content_scroll"),
      setter: (
        layout: (
          padding: Var("space-md"),
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-panel"),
          border: Var("border-default"),
        ),
      ),
    ),
    (
      selector: Class("gallery.page"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-lg"),
          align_items: Stretch,
        ),
      ),
    ),
    (
      selector: Class("gallery.section_title"),
      setter: (
        colors: (
          text: Var("text-heading"),
        ),
        text: (
          size: 24.0,
          weight: 700,
        ),
      ),
    ),
    (
      selector: Class("gallery.page_description"),
      setter: (
        layout: (
          padding: 8.0,
        ),
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: 14.0,
        ),
      ),
    ),
    (
      selector: Class("gallery.card_grid"),
      setter: (
        layout: (
          gap: Var("gap-md"),
          align_items: Start,
        ),
      ),
    ),
    (
      selector: Class("gallery.card"),
      setter: (
        layout: (
          padding: Var("space-xl"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("fill-card-default"),
          border: Var("border-default"),
        ),
        box_shadow: Var("shadow-ui-component"),
      ),
    ),
    (
      selector: Class("gallery.card_title"),
      setter: (
        colors: (
          text: Var("accent-primary"),
        ),
        text: (
          size: Var("text-md"),
          weight: 600,
        ),
      ),
    ),
    (
      selector: Class("gallery.group_box"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.note"),
      setter: (
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: 13.0,
        ),
      ),
    ),
    (
      selector: Class("gallery.placeholder"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("status-warning-bg"),
          border: Var("status-warning-border"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.accent_button"),
      setter: (
        colors: (
          bg: Var("surface-accent"),
          hover_bg: Var("surface-accent-hover"),
          pressed_bg: Var("surface-accent-pressed"),
          border: Var("surface-accent"),
          text: Var("text-on-accent"),
        ),
      ),
    ),
    (
      selector: Class("gallery.flat_button"),
      setter: (
        colors: (
          bg: Var("transparent"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
          border: Var("transparent"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.danger_button"),
      setter: (
        colors: (
          bg: Var("status-error-bg"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
          border: Var("status-error-border"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.swatch.red"),
      setter: (
        layout: (
          padding: 14.0,
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Hex("#E5484D"),
          border: Hex("#FFB3B5"),
          text: Hex("#FFFFFF"),
        ),
        text: (
          text_align: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.swatch.green"),
      setter: (
        layout: (
          padding: 14.0,
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Hex("#2E7D32"),
          border: Hex("#9AD89F"),
          text: Hex("#FFFFFF"),
        ),
        text: (
          text_align: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.swatch.blue"),
      setter: (
        layout: (
          padding: 14.0,
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Hex("#2563EB"),
          border: Hex("#A9C4FF"),
          text: Hex("#FFFFFF"),
        ),
        text: (
          text_align: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.swatch.gold"),
      setter: (
        layout: (
          padding: 14.0,
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Hex("#B45309"),
          border: Hex("#F8D285"),
          text: Hex("#FFFFFF"),
        ),
        text: (
          text_align: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.canvas"),
      setter: (
        layout: (
          padding: 0.0,
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
        ),
      ),
    ),
    (
      selector: Class("gallery.image"),
      setter: (
        layout: (
          padding: 0.0,
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("gallery.icon"),
      setter: (
        colors: (
          text: Var("accent-primary"),
        ),
        text: (
          size: 26.0,
          text_align: Center,
        ),
        font_family: [
          "Segoe Fluent Icons",
          "Segoe MDL2 Assets",
          "FabricMDL2Icons",
          "Segoe UI Symbol",
        ],
      ),
    ),
    (
      selector: Class("gallery.icon_label"),
      setter: (
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: 12.0,
          text_align: Center,
        ),
      ),
    ),
    (
      selector: Class("gallery.typo.hero"),
      setter: (
        colors: (
          text: Var("text-heading"),
        ),
        text: (
          size: 32.0,
          weight: 700,
        ),
      ),
    ),
    (
      selector: Class("gallery.typo.title"),
      setter: (
        colors: (
          text: Var("text-heading"),
        ),
        text: (
          size: 24.0,
          weight: 600,
        ),
      ),
    ),
    (
      selector: Class("gallery.typo.body"),
      setter: (
        colors: (
          text: Var("text-primary"),
        ),
        text: (
          size: 16.0,
        ),
      ),
    ),
    (
      selector: Class("gallery.typo.caption"),
      setter: (
        colors: (
          text: Var("text-secondary"),
        ),
        text: (
          size: 12.0,
        ),
      ),
    ),
    (
      selector: Class("gallery.markdown"),
      setter: (
        layout: (
          padding: Var("space-sm"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
        text: (
          size: 14.0,
          line_height: 1.45,
        ),
      ),
    ),
    (
      selector: Class("gallery.split_panel"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
        ),
      ),
    ),
    (
      selector: Class("gallery.table"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
      ),
    ),
    (
      selector: Class("gallery.progress"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
          text: Var("text-primary"),
        ),
      ),
    ),
  ],
)
