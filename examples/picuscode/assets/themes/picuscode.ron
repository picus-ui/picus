(
  default_variant: "dark",
  rules: [
    (
      selector: Class("picuscode.root"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.titlebar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
          align_items: Center,
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.title"),
      setter: (
        text: (
          size: 18.0,
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.subtitle"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.toolbar.button"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-md"),
          align_items: Center,
        ),
        colors: (
          bg: Var("surface-subtle"),
          text: Var("text-primary"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.toolbar.button.text"),
      setter: (
        text: (
          size: Var("font-size-body1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip"),
      setter: (
        layout: (
          padding: Var("space-xs"),
          corner_radius: Var("radius-sm"),
        ),
        text: (
          size: Var("font-size-caption1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.accent"),
      setter: (
        colors: (
          bg: Var("status-info-bg"),
          text: Var("status-info-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.success"),
      setter: (
        colors: (
          bg: Var("status-success-bg"),
          text: Var("status-success-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.danger"),
      setter: (
        colors: (
          bg: Var("status-error-bg"),
          text: Var("status-error-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.body"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("gap-md"),
          flex_grow: 1.0,
          align_items: Stretch,
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.scroll"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("space-none"),
          flex_grow: 1.0,
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.heading"),
      setter: (
        text: (
          size: Var("font-size-body2"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.caption"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.item"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-md"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          text: Var("text-primary"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.item.active"),
      setter: (
        colors: (
          bg: Var("status-info-bg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.title"),
      setter: (
        text: (
          size: Var("font-size-body1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.title.active"),
      setter: (
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.preview"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
          line_height: Var("line-height-caption1"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.meta"),
      setter: (
        text: (
          size: Var("font-size-caption2"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript.scroll"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("space-none"),
          flex_grow: 1.0,
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-bg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript.header"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript.title"),
      setter: (
        text: (
          size: Var("font-size-subtitle1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript.subtitle"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.empty.panel"),
      setter: (
        layout: (
          padding: Var("space-xl"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.empty.title"),
      setter: (
        text: (
          size: Var("font-size-subtitle2"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.empty.body"),
      setter: (
        text: (
          size: Var("font-size-body1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.user-bubble"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
        ),
        colors: (
          bg: Var("brand-bg"),
          text: Var("text-on-brand"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.composer"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.composer.helper"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.status"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-md"),
        ),
        colors: (
          bg: Var("surface-panel"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.status.primary"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.status.secondary"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.about.root"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.about.heading"),
      setter: (
        text: (
          size: 24.0,
          weight: 700.0,
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.root"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.form"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.header"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.title"),
      setter: (
        text: (
          size: Var("font-size-title3"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.subtitle"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.section"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.section.title"),
      setter: (
        text: (
          size: Var("font-size-subtitle2"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.label"),
      setter: (
        text: (
          size: Var("font-size-body1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.settings.status"),
      setter: (
        layout: (
          padding: Var("space-md"),
          corner_radius: Var("radius-md"),
        ),
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          bg: Var("status-info-bg"),
          text: Var("status-info-fg"),
        ),
      ),
    ),
  ],
)
