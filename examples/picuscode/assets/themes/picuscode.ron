          text: Var("brand-foreground"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.thread.preview"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
          line_height: Var("line-height-caption1"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
