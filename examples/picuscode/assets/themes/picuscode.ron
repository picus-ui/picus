(
  rules: [
    (
      selector: Class("picuscode.root"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.titlebar"),
      setter: (
        layout: (
          padding: Var("space-xs"),
          gap: Var("gap-sm"),
        ),
        colors: (
          bg: Var("surface-bg-secondary"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.title"),
      setter: (
        text: (
          size: 16.0,
          weight: 600.0,
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.transcript"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.user-bubble"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
        ),
        colors: (
          bg: Var("brand-bg"),
          text: Var("text-on-brand"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.composer"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          gap: Var("gap-sm"),
        ),
        colors: (
          bg: Var("surface-bg-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.status"),
      setter: (
        text: (
          size: 12.0,
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.about.root"),
      setter: (
        layout: (
          padding: Var("space-lg"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.about.heading"),
      setter: (
        text: (
          size: 24.0,
          weight: 700.0,
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
  ],
)