(
  default_variant: "dark",
  tokens: {
    "surface-bg": Color(Hex("#090A0C")),
    "surface-panel": Color(Hex("#101218")),
    "surface-elevated": Color(Hex("#171A22")),
    "surface-subtle": Color(Hex("#161922")),
    "surface-subtle-hover": Color(Hex("#202431")),
    "surface-subtle-pressed": Color(Hex("#0D0F14")),
    "surface-overlay": Color(Hex("#171A22")),
    "surface-accent": Color(Hex("#FF6A3D")),
    "surface-accent-hover": Color(Hex("#FF7F56")),
    "surface-accent-pressed": Color(Hex("#D95733")),
    "brand-bg": Color(Hex("#FF6A3D")),
    "brand-bg-hover": Color(Hex("#FF7F56")),
    "brand-bg-pressed": Color(Hex("#D95733")),
    "brand-foreground": Color(Hex("#FF8A5C")),
    "accent-primary": Color(Hex("#FF6A3D")),
    "border-default": Color(Hex("#343945")),
    "border-muted": Color(Hex("#252A34")),
    "border-subtle": Color(Hex("#1D222C")),
    "border-default-hover": Color(Hex("#4A5262")),
    "border-default-pressed": Color(Hex("#2A303B")),
    "text-primary": Color(Hex("#F4F5F7")),
    "text-heading": Color(Hex("#FFFFFF")),
    "text-secondary": Color(Hex("#B9BEC8")),
    "text-tertiary": Color(Hex("#858B96")),
    "text-on-accent": Color(Hex("#160D09")),
    "text-on-brand": Color(Hex("#160D09")),
    "status-info-bg": Color(Hex("#2A1C17")),
    "status-info-fg": Color(Hex("#FF9A6B")),
    "status-success-bg": Color(Hex("#14261B")),
    "status-success-fg": Color(Hex("#74C98A")),
    "status-warning-bg": Color(Hex("#302515")),
    "status-warning-fg": Color(Hex("#D9A441")),
    "status-error-bg": Color(Hex("#331B1D")),
    "status-error-fg": Color(Hex("#E57576")),
    "scrollbar-track": Color(Hex("#FFFFFF08")),
    "scrollbar-thumb": Color(Hex("#FFFFFF3A")),
    "scrollbar-thumb-hover": Color(Hex("#FFFFFF58")),
    "scrollbar-thumb-pressed": Color(Hex("#FF6A3D88")),
  },
  rules: [
    (
      selector: Class("picuscode.root"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.titlebar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
          align_items: Center,
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.title"),
      setter: (
        text: (
          size: 18.0,
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.subtitle"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.toolbar.button"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-sm"),
          corner_radius: Var("radius-md"),
          align_items: Center,
        ),
        colors: (
          bg: Var("surface-subtle"),
          text: Var("text-primary"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.toolbar.button.text"),
      setter: (
        text: (
          size: Var("font-size-body1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip"),
      setter: (
        layout: (
          padding: Var("space-xs"),
          corner_radius: Var("radius-sm"),
        ),
        text: (
          size: Var("font-size-caption1"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.accent"),
      setter: (
        colors: (
          bg: Var("status-info-bg"),
          text: Var("status-info-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.success"),
      setter: (
        colors: (
          bg: Var("status-success-bg"),
          text: Var("status-success-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.chip.danger"),
      setter: (
        colors: (
          bg: Var("status-error-bg"),
          text: Var("status-error-fg"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.body"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("gap-md"),
          flex_grow: 1.0,
          align_items: Stretch,
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar"),
      setter: (
        layout: (
          padding: Var("space-md"),
          gap: Var("gap-md"),
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.scroll"),
      setter: (
        layout: (
          padding: Var("space-none"),
          gap: Var("space-none"),
          flex_grow: 1.0,
          corner_radius: Var("radius-lg"),
        ),
        colors: (
          bg: Var("surface-panel"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.heading"),
      setter: (
        text: (
          size: Var("font-size-body2"),
          weight: Var("font-weight-semibold"),
        ),
        colors: (
          text: Var("text-heading"),
        ),
      ),
    ),
    (
      selector: Class("picuscode.sidebar.caption"),
      setter: (
        text: (
          size: Var("font-size-caption1"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
