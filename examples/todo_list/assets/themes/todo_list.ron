(
  default_variant: "dark",
  rules: [
    (
      selector: Class("todo.root"),
      setter: (
        layout: (
          padding: Var("space-xl"),
          gap: Var("gap-md"),
        ),
        colors: (
          bg: Var("surface-bg"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("todo.header"),
      setter: (
        text: (
          size: 48.0,
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("todo.input-area"),
      setter: (
        layout: (
          gap: Var("gap-sm"),
        ),
      ),
    ),
    (
      selector: Class("todo.input"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-panel"),
          border: Var("border-default"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("todo.add-button"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-accent"),
          hover_bg: Var("surface-accent-hover"),
          pressed_bg: Var("surface-accent-pressed"),
          border: Var("surface-accent"),
          text: Var("text-on-accent"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
    (
      selector: Class("todo.list-container"),
      setter: (
        layout: (
          gap: Var("gap-sm"),
        ),
      ),
    ),
    (
      selector: Class("todo.list-viewport"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-lg"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-panel"),
          border: Var("border-default"),
        ),
        box_shadow: Var("shadow-ui-component"),
      ),
    ),
    (
      selector: Class("todo.empty"),
      setter: (
        text: (
          size: Var("text-sm"),
        ),
        colors: (
          text: Var("text-secondary"),
        ),
      ),
    ),
    (
      selector: Class("todo.item"),
      setter: (
        layout: (
          padding: Var("space-sm"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          border: Var("border-default"),
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("todo.item-checkbox"),
      setter: (
        text: (
          size: Var("text-md"),
        ),
        colors: (
          text: Var("text-primary"),
        ),
      ),
    ),
    (
      selector: Class("todo.delete-button"),
      setter: (
        layout: (
          padding: Var("space-xs"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("status-error-bg"),
          hover_bg: Var("status-error-border"),
          pressed_bg: Var("surface-overlay-item-pressed"),
          border: Var("status-error-border"),
          text: Var("text-primary"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
    (
      selector: Class("todo.filter-bar"),
      setter: (
        layout: (
          gap: Var("gap-sm"),
        ),
      ),
    ),
    (
      selector: Class("todo.filter-toggle"),
      setter: (
        layout: (
          padding: Var("space-xs"),
          corner_radius: Var("radius-md"),
          border_width: Var("border-thin"),
        ),
        colors: (
          bg: Var("surface-subtle"),
          hover_bg: Var("surface-subtle-hover"),
          pressed_bg: Var("surface-subtle-pressed"),
          border: Var("border-default"),
          text: Var("text-primary"),
        ),
        text: (
          size: Var("text-sm"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
  ],
)
