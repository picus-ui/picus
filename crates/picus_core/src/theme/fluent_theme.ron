          corner_radius: Var("radius-pill"),
        ),
        colors: (
          bg: Var("scrollbar-thumb"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
    (
      selector: Class("template.scroll_view.thumb.horizontal"),
      setter: (
        layout: (
          corner_radius: Var("radius-pill"),
        ),
        colors: (
          bg: Var("scrollbar-thumb"),
        ),
        transition: Var("duration-fast"),
      ),
    ),
    (
      selector: And([Class("template.scroll_view.thumb.vertical"), PseudoClass(Hovered)]),
      setter: (
        colors: (
          bg: Var("scrollbar-thumb-hover"),
        ),
      ),
    ),
    (
      selector: And([Class("template.scroll_view.thumb.horizontal"), PseudoClass(Hovered)]),
      setter: (
        colors: (
          bg: Var("scrollbar-thumb-hover"),
        ),
      ),
    ),
    (
      selector: And([Class("template.scroll_view.thumb.vertical"), PseudoClass(Pressed)]),
      setter: (
        layout: (
          scale: 0.98,
        ),
        colors: (
          bg: Var("scrollbar-thumb-pressed"),
        ),
      ),
    ),
    (
      selector: And([Class("template.scroll_view.thumb.horizontal"), PseudoClass(Pressed)]),
      setter: (
        layout: (
          scale: 0.98,
        ),
        colors: (
          bg: Var("scrollbar-thumb-pressed"),
        ),
      ),
    ),
