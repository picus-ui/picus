(
  default_variant: "dark",
  tokens: {
    "transparent": Color(Rgba(0.0, 0.0, 0.0, 0.0)),
    // Border radius matching Fluent v9 borderRadii
    "radius-none": Float(0.0),
    "radius-xs": Float(2.0),
    "radius-sm": Float(4.0),
    "radius-md": Float(6.0),
    "radius-lg": Float(8.0),
    "radius-xl": Float(12.0),
    "radius-2xl": Float(16.0),
    "radius-3xl": Float(24.0),
    "radius-4xl": Float(32.0),
    "radius-5xl": Float(40.0),
    "radius-pill": Float(999.0),
    // Spacing matching Fluent v9 spacing scale
    "space-none": Float(0.0),
    "space-xxs": Float(2.0),
    "space-xs": Float(4.0),
    "space-sm": Float(6.0),
    "space-md": Float(8.0),
    "space-lg": Float(10.0),
    "space-m": Float(12.0),
    "space-xl": Float(16.0),
    "space-xxl": Float(24.0),
    "space-xxxl": Float(32.0),
    // Gap tokens for flex layouts
    "gap-sm": Float(6.0),
    "gap-md": Float(8.0),
    "gap-lg": Float(10.0),
    // Stroke width matching Fluent v9 strokeWidths
    "border-thin": Float(1.0),
    "border-thick": Float(2.0),
    "border-thicker": Float(3.0),
    "border-thickest": Float(4.0),
    "text-sm": Float(15.0),
    "text-md": Float(16.0),
    "text-lg": Float(22.0),
    // Font sizes matching Fluent v9 type ramp
    "font-size-caption2": Float(10.0),
    "font-size-caption1": Float(12.0),
    "font-size-body1": Float(14.0),
    "font-size-body2": Float(16.0),
    "font-size-subtitle2": Float(16.0),
    "font-size-subtitle1": Float(20.0),
    "font-size-title3": Float(24.0),
    "font-size-title2": Float(28.0),
    "font-size-title1": Float(32.0),
    "font-size-large-title": Float(40.0),
    "font-size-display": Float(68.0),
    // Font weights matching OpenType / Fluent conventions
    "font-weight-regular": Float(400.0),
    "font-weight-medium": Float(500.0),
    "font-weight-semibold": Float(600.0),
    "font-weight-bold": Float(700.0),
    // Relative line-height multipliers
    "line-height-caption2": Float(1.4),
    "line-height-caption1": Float(1.33),
    "line-height-body1": Float(1.43),
    "line-height-body2": Float(1.38),
    "line-height-subtitle2": Float(1.38),
    "line-height-subtitle1": Float(1.4),
    "line-height-title3": Float(1.33),
    "line-height-title2": Float(1.29),
    "line-height-title1": Float(1.25),
    "line-height-large-title": Float(1.3),
    "line-height-display": Float(1.35),
    // Font families matching Fluent v9 fontFamily tokens
    "font-family-base": FontFamily(["'Segoe UI'", "'Segoe UI Web (West European)'", "-apple-system", "BlinkMacSystemFont", "Roboto", "'Helvetica Neue'", "sans-serif"]),
    "font-family-monospace": FontFamily(["Consolas", "'Courier New'", "Courier", "monospace"]),
    "font-family-numeric": FontFamily(["Bahnschrift", "'Segoe UI'", "'Segoe UI Web (West European)'", "-apple-system", "BlinkMacSystemFont", "Roboto", "'Helvetica Neue'", "sans-serif"]),
    // Duration matching Fluent v9 durations
    "duration-ultra-fast": Float(0.05),
    "duration-faster": Float(0.10),
    "duration-fast": Float(0.15),
    "duration-normal": Float(0.20),
    "duration-gentle": Float(0.25),
    "duration-slow": Float(0.30),
    "duration-slower": Float(0.40),
    "duration-ultra-slow": Float(0.50),
    // Easing curves matching Fluent v9 curve tokens
    "curve-accelerate-max": Curve(0.9, 0.1, 1.0, 0.2),
    "curve-accelerate-mid": Curve(1.0, 0.0, 1.0, 1.0),
    "curve-accelerate-min": Curve(0.8, 0.0, 0.78, 1.0),
    "curve-decelerate-max": Curve(0.1, 0.9, 0.2, 1.0),
    "curve-decelerate-mid": Curve(0.0, 0.0, 0.0, 1.0),
    "curve-decelerate-min": Curve(0.33, 0.0, 0.1, 1.0),
    "curve-easy-ease-max": Curve(0.8, 0.0, 0.2, 1.0),
    "curve-easy-ease": Curve(0.33, 0.0, 0.67, 1.0),
    "curve-linear": Curve(0.0, 0.0, 1.0, 1.0),
    // Transition presets: duration + easing combinations
    "transition-fast": Transition(StyleTransition(duration: 0.15, easing: None)),
    "transition-normal": Transition(StyleTransition(duration: 0.20, easing: None)),
    "transition-smooth": Transition(StyleTransition(duration: 0.20, easing: Some(EasyEase))),
    "transition-slow": Transition(StyleTransition(duration: 0.30, easing: Some(DecelerateMax))),
    // Z-index stack (matching Fluent v9 zIndex tokens)
    "zindex-base": Float(0.0),
    "zindex-dropdown": Float(1000.0),
    "zindex-popover": Float(2000.0),
    "zindex-dialog": Float(3000.0),
    "zindex-toast": Float(4000.0),
    // Avatar colour palette tokens (Fluent UI v9 named colours)
    "avatar-bg-dark-red": Color(Hex("#C75050")),
    "avatar-bg-cranberry": Color(Hex("#C75050")),
    "avatar-bg-red": Color(Hex("#E37D5C")),
    "avatar-bg-pumpkin": Color(Hex("#E37D5C")),
    "avatar-bg-peach": Color(Hex("#FFC7A0")),
    "avatar-bg-marigold": Color(Hex("#E3A95C")),
    "avatar-bg-gold": Color(Hex("#E3C75C")),
    "avatar-bg-brass": Color(Hex("#B5B549")),
    "avatar-bg-brown": Color(Hex("#AF8B60")),
    "avatar-bg-forest": Color(Hex("#5C9E5C")),
    "avatar-bg-seafoam": Color(Hex("#5CB0B0")),
    "avatar-bg-dark-green": Color(Hex("#2E7D32")),
    "avatar-bg-light-teal": Color(Hex("#5CB0B0")),
    "avatar-bg-teal": Color(Hex("#3E8D8D")),
    "avatar-bg-steel": Color(Hex("#5C7DB0")),
    "avatar-bg-blue": Color(Hex("#5C7DB0")),
    "avatar-bg-royal-blue": Color(Hex("#3650A0")),
    "avatar-bg-cornflower": Color(Hex("#7C9BD8")),
    "avatar-bg-navy": Color(Hex("#36477D")),
    "avatar-bg-lavender": Color(Hex("#9B8FC2")),
    "avatar-bg-purple": Color(Hex("#8D6BB5")),
    "avatar-bg-grape": Color(Hex("#6B4F8D")),
    "avatar-bg-lilac": Color(Hex("#B59AD5")),
    "avatar-bg-pink": Color(Hex("#D8739A")),
    "avatar-bg-magenta": Color(Hex("#BB5F9B")),
    "avatar-text-on-dark": Color(Hex("#FFFFFF")),
    "avatar-text-on-light": Color(Hex("#1F1F1F")),
  },
  rules: [
    (
      selector: Type("UiRoot"),
      setter: (
        layout: (
          justify_content: Start,
          align_items: Stretch,
        ),
        colors: (
          bg: Var("surface-bg"),
        ),
      ),
    ),
    (
      selector: Type("UiFlexColumn"),
      setter: (
        layout: (
          gap: Var("gap-md"),
          justify_content: Start,
          align_items: Stretch,
        ),
      ),
    ),
    (
      selector: Type("UiFlexRow"),
      setter: (
        layout: (
          gap: Var("gap-md"),
          justify_content: Start,
          align_items: Center,
        ),
      ),
    ),
    (
      selector: Type("UiLabel"),
      setter: (
